# Server
PORT=5000
NODE_ENV=development

# Database (set these manually, or Railway auto-injects MYSQLHOST/MYSQLPORT/MYSQLUSER/MYSQLPASSWORD/MYSQLDATABASE)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=expensewise

# JWT Secrets (use strong random strings in production)
JWT_SECRET=expensewise_jwt_access_secret_key_change_me
JWT_REFRESH_SECRET=expensewise_jwt_refresh_secret_key_change_me

# CORS - set to your Vercel frontend URL in production
FRONTEND_URL=https://your-app.vercel.app
